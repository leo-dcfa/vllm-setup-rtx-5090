# Copy to .env (chmod 600). All values optional.

# HuggingFace token — only needed for gated repos (e.g. the official
# Qwen/Qwen3.6-*-GPTQ-Int4 mirrors). The defaults in the Makefile are ungated.
HF_TOKEN=

# Override the vLLM docker image tags if you pin a specific build.
# Blackwell (sm_120) needs a CUDA 12.8+/13.0 image.
# VLLM_IMAGE=vllm/vllm-openai:latest
# GEMMA_IMAGE=vllm/vllm-openai:gemma4-0505-cu130
