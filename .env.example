# Copy to .env (chmod 600). All values optional.

# HuggingFace token — only needed for gated repos (e.g. the official
# Qwen/Qwen3.6-*-GPTQ-Int4 mirrors). The defaults in the Makefile are ungated.
HF_TOKEN=

# Override the vLLM docker image. Native sm_120 (RTX 5090) NVFP4 needs a current
# build that recognizes sm_120 in the FP4 backend selection (FlashInfer-CUTLASS,
# not the Marlin fallback). Use the cu130 nightly; stable tags are cu129-only.
# VLLM_IMAGE=vllm/vllm-openai:cu130-nightly
